    c.strokeStyle = p.shadow; c.globalAlpha = .13; c.lineWidth = 3;
    for (let i = 0; i < 11; i++) {
      const base = ((i * 170 - this.cameraY * (.05 + i * .002)) % (H + 160)) - 80;
      c.beginPath();
      for (let x = -20; x <= W + 20; x += 40) {
        const y = base + Math.sin(x * .012 + i) * 16;
        if (x === -20) c.moveTo(x, y); else c.lineTo(x, y);
      }
      c.stroke();
    }
    c.globalAlpha = 1;

    const visible = this.props.filter((o) => o.y - this.cameraY > -120 && o.y - this.cameraY < H + 120);
    visible.sort((a, b) => a.y - b.y).forEach((o) => this.drawProp(c, o, p));

    if (this.player.y < 320) {
      c.fillStyle = 'rgba(66,232,220,.16)'; c.fillRect(0, 0, W, 110);
      c.strokeStyle = '#42e8dc'; c.lineWidth = 4; c.setLineDash([20, 16]); c.beginPath(); c.moveTo(0, 105); c.lineTo(W, 105); c.stroke(); c.setLineDash([]);
      text(c, 'EXTRACTION ZONE', W / 2, 55, 18, '#d7fffb', 'center');
    }
  }

