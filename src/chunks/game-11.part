      c.strokeStyle = '#263139'; c.lineWidth = 8; c.beginPath(); c.moveTo(0, 34); c.lineTo(0, -30); c.stroke(); c.fillStyle = '#ffe998'; c.shadowColor = '#ffe998'; c.shadowBlur = 20; c.beginPath(); c.arc(0, -35, 10, 0, TAU); c.fill();
    } else if (t === 'vent') {
