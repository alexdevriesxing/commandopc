      c.strokeStyle = 'rgba(255,255,255,.45)'; c.lineWidth = 3; c.beginPath(); c.arc(-8, 0, 20, .3, 2.2); c.stroke();
    } else if (t === 'wall' || t === 'ruin' || t === 'concrete') {
