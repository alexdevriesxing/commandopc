th(); c.arc(0, -23, 8, 0, TAU); c.fill(); c.stroke(); }
    c.restore();
  }

  drawPlaying(c) {
    const shakeX = this.shake > 0 ? rand(-this.shake, this.shake) : 0;
    const shakeY = this.shake > 0 ? rand(-this.shake, this.shake) : 0;
    c.save(); c.translate(shakeX, shakeY);
    this.drawWorld(c);
    this.decals.forEach((d) => d.draw(c, this.cameraY));
    this.drawTargets(c);
    this.pickups.forEach((p) => p.draw(c, this.cameraY));
    this.enemies.slice().sort((a, b) => a.y - b.y).forEach((e) => e.draw(c, this.cameraY));
    this.player.draw(c, this.cameraY);
    this.projectiles.forEach((p) => p.draw(c, this.cameraY));
    this.particles.forEach((p) => p.draw(c, this.cameraY));
    this.floating.forEach((f) => f.draw(c, this.cameraY));
    this.drawWeather(c);
    c.restore();
    this.drawHUD(c);
    this.drawScreenEffects(c);
  }

  drawWorld(c) {
    const p = PALETTES[this.level.palette];
    c.fillStyle = p.sand; c.fillRect(0, 0, W, H);
    const tile = 180;
    const offsetY = -((this.cameraY % tile) + tile) % tile;
    for (let row = -1; row < H / tile + 2; row++) {
      for (let col = 0; col < W / tile + 1; col++) {
        const x = col * tile;
        const y = offsetY + row * tile;
        const worldY = this.cameraY + y;
        const n = hash(col * 7.1 + Math.floor(worldY / tile) * 31 + this.level.id * 17);
        c.fillStyle = n > .62 ? p.sand2 : p.sand;
        c.globalAlpha = .09 + n * .09;
        c.beginPath(); c.ellipse(x + n * tile, y + hash(n * 991) * tile, tile * (.35 + n * .3), tile * .12, n * TAU, 0, TAU); c.fill();
