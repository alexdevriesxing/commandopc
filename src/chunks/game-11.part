    } else if (t === 'tank' || t === 'reactor') {
      c.fillStyle = '#48545a'; c.beginPath(); c.ellipse(0, -20, 30, 14, 0, 0, TAU); c.fill(); c.fillRect(-30, -20, 60, 48); c.beginPath(); c.ellipse(0, 28, 30, 14, 0, 0, TAU); c.fill(); c.stroke();
      c.fillStyle = t === 'reactor' ? '#42e8dc' : '#ff7d3c'; c.fillRect(-30, -3, 60, 8);
