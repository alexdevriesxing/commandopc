      c.strokeStyle = p.foliage; c.lineWidth = 8; for (let i = 0; i < 7; i++) { const a = i / 7 * TAU; c.beginPath(); c.moveTo(-3, -34); c.quadraticCurveTo(Math.cos(a) * 20, -48 + Math.sin(a) * 9, Math.cos(a) * 37, -32 + Math.sin(a) * 22); c.stroke(); }
