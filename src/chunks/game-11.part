      c.fillStyle = '#b9483d'; c.fillRect(-33, -17, 16, 36); c.fillRect(1, -17, 16, 36);
    } else if (t === 'pillar') {
      c.fillStyle = p.wall; c.fillRect(-14, -34, 28, 68); c.strokeRect(-14, -34, 28, 68); c.fillRect(-22, -40, 44, 11); c.strokeRect(-22, -40, 44, 11);
    } else if (t === 'crater') {
      c.fillStyle = 'rgba(30,20,22,.28)'; c.beginPath(); c.ellipse(0, 0, 40, 22, 0, 0, TAU); c.fill(); c.strokeStyle = 'rgba(7,16,24,.4)'; c.stroke();
    } else if (t === 'banner') {
      c.strokeStyle = '#3b2c2e'; c.lineWidth = 7; c.beginPath(); c.moveTo(0, 34); c.lineTo(0, -42); c.stroke(); c.fillStyle = '#8b3441'; c.fillRect(3, -39, 36, 49); c.strokeRect(3, -39, 36, 49);
    } else if (t === 'antenna') {
